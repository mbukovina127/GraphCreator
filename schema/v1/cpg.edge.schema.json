{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema/v1/cpg.edge.schema.json",
  "title": "Universal CPG Edge (v1)",
  "type": "object",
  "required": [
    "source",
    "target",
    "type"
  ],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "description": "The id of the source node ('{project_id}:{internal_key}')."
    },
    "target": {
      "type": "string",
      "description": "The id of the target node ('{project_id}:{internal_key}')."
    },
    "type": {
      "type": "string",
      "description": "Mapped CPG edge type (derived from internal relation via export_cpg_v1).",
      "enum": [
        "AST_CHILD",
        "CONTAINS",
        "FLOWS_TO",
        "CALLS",
        "DEFINES",
        "DECLARES",
        "REFERS_TO",
        "HAS_PARAMETER",
        "RETURNS",
        "IMPORTS"
      ]
    },
    "properties": {
      "type": "object",
      "description": "Edge metadata.",
      "additionalProperties": true,
      "properties": {
        "relation": {
          "type": "string",
          "description": "Internal relation string before mapping (e.g. 'calls', 'refers_to')."
        }
      }
    }
  }
}
