{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema/v1/cpg.node.schema.json",
  "title": "Universal CPG Node (v1)",
  "type": "object",
  "required": [
    "id",
    "type"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique node identifier. Format: '{project_id}:{internal_key}'."
    },
    "type": {
      "type": "string",
      "description": "Mapped CPG node type (derived from internal type via export_cpg_v1).",
      "enum": [
        "FILE",
        "DIRECTORY",
        "FUNCTION",
        "VARIABLE",
        "IDENTIFIER",
        "LITERAL",
        "CALL",
        "CONTROL_STRUCTURE",
        "BLOCK",
        "COMMENT",
        "NAMESPACE",
        "UNKNOWN"
      ]
    },
    "properties": {
      "type": "object",
      "description": "Node metadata. Always contains 'kind' (internal type) and 'language'.",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "description": "Internal CPG type before mapping (e.g. 'local_function_definition')."
        },
        "language": {
          "type": "string",
          "description": "Source language (always 'lua')."
        },
        "code": {
          "type": ["string", "null"],
          "description": "Source text of the originating AST node."
        },
        "name": {
          "type": "string",
          "description": "Symbol name for functions, variables, identifiers, and calls."
        }
      }
    },
    "location": {
      "type": "object",
      "description": "Source location. Present when the node has byte offsets.",
      "additionalProperties": false,
      "properties": {
        "start_offset": {
          "type": ["integer", "null"],
          "description": "Byte offset of the node start in the source file."
        },
        "end_offset": {
          "type": ["integer", "null"],
          "description": "Byte offset of the node end in the source file."
        },
        "file": {
          "type": "string",
          "description": "Absolute path of the source file."
        }
      }
    }
  }
}
