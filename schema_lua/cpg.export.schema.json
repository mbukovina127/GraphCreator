{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema_lua/v1/cpg.export.schema.json",
  "title": "Universal CPG Export (v1)",
  "description": "Validates the JSON produced by the Lua CPG generator.",
  "type": "object",
  "required": [
    "meta_data",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "meta_data": {
      "type": "object",
      "description": "Export metadata.",
      "additionalProperties": true,
      "required": [
        "schema_version"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "description": "Schema version used to produce this export (e.g. 'v1')."
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Languages analyzed (e.g. ['lua'])."
        },
        "analysis_date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the analysis was performed."
        },
        "graph_id": {
          "type": "string",
          "description": "Stable identifier for this graph export (e.g. a project ID)."
        },
        "generator": {
          "type": "string",
          "description": "Name of the tool that produced this export."
        },
        "generator_version": {
          "type": "string",
          "description": "Version of the generator tool."
        }
      }
    },
    "nodes": {
      "type": "array",
      "description": "All knowledge graph nodes.",
      "items": {
        "$ref": "cpg.node.schema.json"
      }
    },
    "edges": {
      "type": "array",
      "description": "All knowledge graph edges.",
      "items": {
        "$ref": "cpg.edge.schema.json"
      }
    }
  }
}
