@startuml GraphCreator_Sequence_Diagram
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontSize 13
skinparam sequenceArrowThickness 1.5
skinparam sequenceGroupBorderThickness 1.5
skinparam sequenceMessageAlign center
skinparam participantPadding 20
skinparam boxPadding 16

skinparam participant {
    BackgroundColor #D6EAF8
    BorderColor #2980B9
    FontSize 13
}
skinparam actor {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    FontSize 13
}
skinparam sequence {
    ArrowFontSize 11
    GroupFontSize 13
    DividerFontSize 13
    DividerBorderThickness 1.5
}
skinparam note {
    BackgroundColor #FEF9E7
    BorderColor #F39C12
    FontSize 11
}

title GraphCreator — Processing Pipeline Sequence

'─────────────── PARTICIPANTS ───────────────
actor "SoftVis\nPublisher"          as publisher
participant "LuaCodeAnalyzer\nService" as svc
participant "Graph Store\nAdapter"  as graphstore
participant "ProjectStructure\nAnalyzer" as proj_struct
participant "RayOrchestrator"       as ray_orch
participant "CGPWorker\n[Ray Actor]" as worker
participant "GraphManager"          as graph_mgr
participant "SymbolBuilder"         as sym_builder
participant "CPGBuilder"            as cpg_builder
participant "SymbolTable"           as sym_table
participant "GraphCollector"        as graph_collector
participant "CPG v1\nExporter"      as exporter
actor "Downstream\nConsumers"       as consumers

'─────────────── FLOW ───────────────

== 1. Task Reception ==

publisher -> svc : process_project(project_id, incremental)
note over publisher, svc
  Delivered via Dapr pub/sub
  (CloudEvents envelope, omitted for clarity)
end note
activate svc

== 2. Download & Extract ==

svc -> graphstore : GET /files/{project_id}
graphstore --> svc : ZIP bytes
svc -> svc : extract ZIP → /tmp/lua-analyzer-{id}/

== 3. Project Structure Analysis ==

svc -> proj_struct : analyze_project_structure(extracted_path)
proj_struct -> proj_struct : recursive walk\n(dirs + .lua files)
proj_struct --> svc : [{name, path, type, parent}, ...]

== 4. Ray-Distributed Parsing ==

svc -> ray_orch : distribute_work(lua_files)
ray_orch -> ray_orch : ray.init()
ray_orch -> worker : CGPWorker.remote() × N

loop for each .lua file (round-robin)
    ray_orch -> worker : analyze_file.remote(file_path)
    activate worker

    worker -> worker : ParallelASTManager.parse(file_path)
    note right of worker
      Each Ray actor owns its own
      tree-sitter parser instance
      (not a singleton).
    end note

    worker -> graph_mgr : generate_graph(ast, file_path)
    activate graph_mgr

    graph_mgr -> graph_mgr : ASTInserter — insert AST nodes/edges

    graph_mgr -> sym_builder : build(ast, file_path)
    activate sym_builder
    sym_builder -> sym_table : register declarations\n(vars, functions, params, imports)
    sym_builder --> graph_mgr : populated SymbolTable
    deactivate sym_builder

    graph_mgr -> cpg_builder : build(root_node, file_path)
    activate cpg_builder

    loop for each AST node (recursive walk)
        cpg_builder -> cpg_builder : push/pop scope (ScopeStack)\ncreate typed knowledge node\n(FUNCTION / VARIABLE / CHUNK / MODULE)
        cpg_builder -> sym_table : scope_lookup_by_name(identifier)
        sym_table -> sym_table : walk scope chain\n(lexical resolution)
        sym_table --> cpg_builder : SymbolID or None
        cpg_builder -> cpg_builder : create relation\n(CALL / ASSIGNMENT / IDENTIFIER\n/ BLOCK / CONTROL_FLOW)
        note right of cpg_builder
          ContextStack disambiguates
          edge type for the same identifier
          node depending on enclosing context
          (VAR_DECL, ARGUMENTS, etc.).
        end note
    end

    cpg_builder --> graph_mgr : local CPG graph
    deactivate cpg_builder

    graph_mgr --> worker : {ast_graph, cpg_graph,\nunresolved_edges, exports, imports}
    deactivate graph_mgr

    worker --> ray_orch : local_graph (future resolved)
    deactivate worker
end

ray_orch -> ray_orch : ray.get(futures) — collect all local graphs

== 5. Graph Aggregation ==

ray_orch -> graph_collector : collect(local_graphs, root_dir)
activate graph_collector
graph_collector -> graph_collector : _create_spine()\n(file-system hierarchy nodes)
graph_collector -> graph_collector : _create_indexes()\n(module + export index)
graph_collector -> graph_collector : _resolve_cross_file_edges()\n(require() + unresolved refs)
graph_collector -> graph_collector : _compute_graph_metrics()\n(project-level + per-function)
graph_collector --> ray_orch : merged CPG graph
deactivate graph_collector

ray_orch --> svc : merged CPG graph

== 6. Export & Validate ==

svc -> exporter : export_cpg_v1(project_id, merged_graph)
exporter -> exporter : map internal types → CPG v1 standard\nprefix IDs: "{project_id}:{node_key}"
exporter --> svc : cpg_v1 dict (validated against JSON schema)

== 7. Publish & Cleanup ==

svc -> consumers : CPG v1 payload (zstd compressed)
note over svc, consumers
  Delivered via Dapr pub/sub "graph-updates"
  and "results" topics (omitted for clarity)
end note

svc -> svc : rmtree(tempdir)
svc --> publisher : ProcessingResult {status, files_processed, errors}
deactivate svc

@enduml
