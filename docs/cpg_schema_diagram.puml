@startuml CPG_Graph_Schema
!theme plain
top to bottom direction
hide empty members

skinparam defaultFontSize 13
skinparam padding 8
skinparam nodesep 45
skinparam ranksep 55

skinparam class {
    BackgroundColor #D6EAF8
    BorderColor #2980B9
    FontSize 13
}
skinparam package {
    BackgroundColor #EBF5FB
    BorderColor #1A5276
    FontSize 14
    FontStyle bold
}
skinparam arrow {
    Color #2C3E50
    FontSize 11
}

'══════════════════════════════════════════════
' FILE SYSTEM SPINE
'══════════════════════════════════════════════
package "File System Spine" as spine {
    class "directory" as dir   << node >>
    class "file"      as file  << node >>
    class "chunk"     as chunk << node >>
    class "module"    as mod   << node >>
}

'══════════════════════════════════════════════
' DECLARATIONS
'══════════════════════════════════════════════
package "Declarations" as decl {
    class "local_function_definition"  as lfunc   << node >>
    class "global_function_definition" as gfunc   << node >>
    class "local_variable_declaration" as lvar_d  << node >>
    class "global_variable_declaration" as gvar_d << node >>
    class "local_variable"             as lvar    << node >>
    class "module_import"              as mod_imp << node >>
}

'══════════════════════════════════════════════
' EXPRESSIONS
'══════════════════════════════════════════════
package "Expressions" as expr {
    class "identifier"        as ident    << node >>
    class "function_call"     as fcall    << node >>
    class "index_expression"  as idx_expr << node >>
    class "binary_expression" as bin_expr << node >>
    class "expression_list"   as expr_lst << node >>
    class "table_constructor" as tbl_ctor << node >>
    class "literal"           as literal  << node >>
}

'══════════════════════════════════════════════
' CONTROL FLOW
'══════════════════════════════════════════════
package "Control Flow" as cf {
    class "block"           as block    << node >>
    class "if_statement"    as if_stmt  << node >>
    class "elseif_statement" as elif_stmt << node >>
    class "else_statement"  as else_stmt << node >>
    class "for_statement\n(numeric / generic)" as for_stmt << node >>
    class "while_statement" as while_stmt << node >>
    class "repeat_statement" as rep_stmt << node >>
    class "return_statement" as ret_stmt  << node >>
}

'══════════════════════════════════════════════
' METRICS
'══════════════════════════════════════════════
package "Metrics" as metrics {
    class "metric\n(Halstead · LOC · Cyclomatic\n· Variables · Dependency\n· Info-Flow · Statements)" as metric << node >>
}

'══════════════════════════════════════════════
' SPINE RELATIONS
'══════════════════════════════════════════════
dir   -[#1A5276]->  dir   : contains
dir   -[#1A5276]->  file  : contains
file  -[#1A5276]->  chunk : contains
file  -[#1A5276]->  mod   : contains

'══════════════════════════════════════════════
' CHUNK → DECLARATIONS
'══════════════════════════════════════════════
chunk -[#1E8449]->  lfunc   : defines
chunk -[#1E8449]->  gfunc   : defines
chunk -[#1E8449]->  lvar_d  : declares
chunk -[#1E8449]->  gvar_d  : declares
chunk -[#1E8449]->  mod_imp : imports

'══════════════════════════════════════════════
' MODULE IMPORT RESOLUTION
'══════════════════════════════════════════════
mod_imp -[#8E44AD]->  mod : refers_to

'══════════════════════════════════════════════
' FUNCTION INTERNALS
'══════════════════════════════════════════════
lfunc  -[#2980B9]->  block   : has_block
gfunc  -[#2980B9]->  block   : has_block
lfunc  -[#2980B9]->  lvar    : has_parameter
gfunc  -[#2980B9]->  lvar    : has_parameter
lfunc  -[#2980B9]->  metric  : has_metrics
gfunc  -[#2980B9]->  metric  : has_metrics
chunk  -[#2980B9]->  metric  : has_metrics

'══════════════════════════════════════════════
' VARIABLE DECLARATION
'══════════════════════════════════════════════
lvar_d -[#CA6F1E]->  lvar    : declares
lvar_d -[#CA6F1E]->  expr_lst : initializes

'══════════════════════════════════════════════
' BLOCK CONTENTS
'══════════════════════════════════════════════
block -[#C0392B]->  if_stmt   : contains
block -[#C0392B]->  for_stmt  : contains
block -[#C0392B]->  while_stmt : contains
block -[#C0392B]->  rep_stmt  : contains
block -[#C0392B]->  ret_stmt  : contains
block -[#C0392B]->  fcall     : contains
block -[#C0392B]->  lvar      : captures

'══════════════════════════════════════════════
' CONTROL FLOW BRANCHING
'══════════════════════════════════════════════
if_stmt   -[#C0392B]->  expr_lst  : has_condition
if_stmt   -[#C0392B]->  block     : has_block
if_stmt   -[#C0392B]->  elif_stmt : executes
if_stmt   -[#C0392B]->  else_stmt : executes
elif_stmt -[#C0392B]->  expr_lst  : has_condition
elif_stmt -[#C0392B]->  block     : has_block
else_stmt -[#C0392B]->  block     : has_block
for_stmt  -[#C0392B]->  block     : has_block
for_stmt  -[#C0392B]->  expr_lst  : has_condition
while_stmt -[#C0392B]-> expr_lst  : has_condition
while_stmt -[#C0392B]-> block     : has_block
rep_stmt  -[#C0392B]->  expr_lst  : has_condition
rep_stmt  -[#C0392B]->  block     : has_block
ret_stmt  -[#C0392B]->  expr_lst  : returns

'══════════════════════════════════════════════
' FUNCTION CALL
'══════════════════════════════════════════════
fcall -[#8E44AD]->  lfunc    : calls
fcall -[#8E44AD]->  gfunc    : calls
fcall -[#8E44AD]->  expr_lst : has_argument

'══════════════════════════════════════════════
' EXPRESSION COMPOSITION
'══════════════════════════════════════════════
expr_lst -[#17A589]->  ident    : contains
expr_lst -[#17A589]->  fcall    : contains
expr_lst -[#17A589]->  literal  : contains
expr_lst -[#17A589]->  bin_expr : contains
expr_lst -[#17A589]->  tbl_ctor : contains
expr_lst -[#17A589]->  idx_expr : contains
idx_expr -[#17A589]->  ident    : has_field
bin_expr -[#17A589]->  expr_lst : contains

'══════════════════════════════════════════════
' IDENTIFIER RESOLUTION (DATA FLOW)
'══════════════════════════════════════════════
ident -[#E74C3C]--> lvar_d : refers_to
ident -[#E74C3C]--> gvar_d : refers_to
ident -[#E74C3C]--> lvar   : refers_to
ident -[#E74C3C]--> lvar_d : assigns_to

@enduml